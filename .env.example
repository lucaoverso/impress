# Impressora padrao do CUPS (veja com: lpstat -p)
CUPS_PRINTER=HP_LaserJet

# Diretorio persistente para uploads e PDFs temporarios
SPOOL_DIR=/var/spool/sistema-impress

# Caminho do banco SQLite fora da pasta do codigo
DB_PATH=/opt/sistema-impress-data/impressao.db

# API sem worker embutido quando existir servico dedicado
ENABLE_EMBEDDED_WORKER=false

# Manter arquivos do spool para permitir preview e reimpressao do historico
KEEP_SPOOL_FILES=true

# Quando maior que zero, remove arquivos do spool apos N dias
SPOOL_RETENTION_DAYS=7

# INFO, WARNING, ERROR ou DEBUG
LOG_LEVEL=INFO

# TTL do token de login: apenas 7 ou 15
TOKEN_TTL_DIAS=7

# Tempo minimo para permitir cancelamento antes do envio ao CUPS
PRINT_CANCEL_WINDOW_SECONDS=15

# Versao opcional para cache busting dos arquivos estaticos
# STATIC_ASSET_VERSION=release-2026-04-13

# Segredo do endpoint interno usado na integracao com FreeRADIUS
# Deixe vazio se essa integracao nao for usada
RADIUS_INTERNAL_SECRET=

# Comando do CUPS. Pode ser um nome no PATH ou caminho absoluto
CUPS_LP_COMMAND=lp
CUPS_LP_TIMEOUT_SECONDS=30

# Comando do LibreOffice para converter DOC/DOCX
# Se o binario nao estiver no PATH, use o caminho absoluto
LIBREOFFICE_COMMAND=soffice

# Runtimes JS do yt-dlp para extracao do YouTube.
# Se vazio, o sistema tenta usar "node" automaticamente quando estiver no PATH.
# Exemplos:
# YTDLP_JS_RUNTIMES=node
# YTDLP_JS_RUNTIMES=node:/usr/bin/node
YTDLP_JS_RUNTIMES=

# Clientes opcionais do extrator do YouTube, separados por virgula
# Exemplo: YTDLP_YOUTUBE_PLAYER_CLIENTS=android,web
YTDLP_YOUTUBE_PLAYER_CLIENTS=
